{
  "name": "@setu/docs-embeddings",
  "version": "1.0.0",
  "type": "module",
  "description": "Incremental embedding generation and vector database sync with AWS Bedrock",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "sync": "yarn build && yarn start",
    "dry-run": "yarn build && node dist/index.js --dry-run",
    "embed-all": "yarn build && node dist/embed-all.js",
    "verify-embed": "yarn build && node dist/verify-embed.js"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.490.0",
    "@aws-sdk/client-s3": "^3.490.0",
    "@pinecone-database/pinecone": "^2.0.0",
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3"
  }
}
