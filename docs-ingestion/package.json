{
  "name": "@setu/docs-ingestion",
  "version": "1.0.0",
  "description": "Documentation ingestion pipeline for Setu docs copilot",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "ingest": "npm run build && npm start",
    "dev": "tsx src/index.ts",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js"
  },
  "keywords": [
    "documentation",
    "ingestion",
    "markdown",
    "chunking"
  ],
  "author": "Setu",
  "license": "MIT",
  "dependencies": {
    "@types/node": "^20.10.0",
    "gray-matter": "^4.0.3",
    "js-tiktoken": "^1.0.7",
    "mdast-util-from-markdown": "^2.0.0",
    "mdast-util-mdx": "^3.0.0",
    "mdast-util-to-string": "^4.0.0",
    "micromark-extension-mdxjs": "^3.0.0",
    "simple-git": "^3.21.0",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "jest": "^29.5.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
