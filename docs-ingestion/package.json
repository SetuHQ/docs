{
  "name": "@setu/docs-ingestion",
  "version": "1.0.0",
  "description": "Documentation ingestion pipeline for Setu docs copilot",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "ingest": "yarn build && yarn start",
    "upload-content": "yarn build && node dist/upload-content.js",
    "normalize-mdx": "yarn build && node dist/normalize-mdx.js",
    "normalize-api-specs": "yarn build && node dist/normalize-api-specs.js",
    "check-token-limits": "tsx scripts/check-token-limits.ts",
    "smoke-test-ingestion": "yarn build && tsx scripts/smoke-test-ingestion.ts",
    "dev": "tsx src/index.ts",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js"
  },
  "keywords": [
    "documentation",
    "ingestion",
    "markdown",
    "chunking"
  ],
  "author": "Setu",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.490.0",
    "@types/node": "^20.10.0",
    "dotenv": "^17.2.3",
    "gray-matter": "^4.0.3",
    "js-tiktoken": "^1.0.7",
    "mdast-util-from-markdown": "^2.0.0",
    "mdast-util-mdx": "^3.0.0",
    "mdast-util-to-string": "^4.0.0",
    "micromark-extension-mdxjs": "^3.0.0",
    "simple-git": "^3.21.0",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "packageManager": "yarn@4.12.0+sha512.f45ab632439a67f8bc759bf32ead036a1f413287b9042726b7cc4818b7b49e14e9423ba49b18f9e06ea4941c1ad062385b1d8760a8d5091a1a31e5f6219afca8"
}
